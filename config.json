    },
    "wiki": {
      "max_words": 120,
      "min_words": 15
    },
    "ai": {
      "target_words": 100,
      "max_words": 140,
      "min_words": 60,
      "model": "deepseek/deepseek-chat-v3-0324:free"
    }
  },
  "audio": {
    "voice": "en-US-ChristopherNeural",
    "rate": "+0%",
    "volume": "+0%"
  },
  "video": {
    "whisper_model": "base",
    "subtitle": {
      "min_words": 1,
      "max_words": 3,
      "font_size": 84,
      "stroke_width": 6
    },
    "output": {
      "width": 1080,
      "height": 1920,
      "fps": 30
    }
  },
  "uploader": {
    "enabled": true,
