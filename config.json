{
  "scheduler": {
    "times": [
      "08:00",
      "17:00"
    ],
    "extra_times": [],
    "run_on_start": false,
    "recovery_sleep_seconds": 5
  },
  "paths": {
    "output_dir": "output",
    "cookies_dir": "cookies",
    "background_video": "assets/gameplay.mp4",
    "history_db": "history.db"
  },
  "scrapers": {
